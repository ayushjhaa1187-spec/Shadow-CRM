# ============================================================
# Shadow CRM — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values.

# ----- Supabase (required) -----
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# ----- AI / OpenAI (optional — enables full AI chat) -----
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"

# ----- Legacy Backend (optional — for Express server) -----
DATABASE_URL="postgresql://user:password@localhost:5432/shadow_crm"
REDIS_URL="redis://localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT="6379"
PORT=3000
NODE_ENV="development"

# ----- Webhook Secrets (optional) -----
HUBSPOT_WEBHOOK_SECRET="your-hubspot-secret"
PIPEDRIVE_WEBHOOK_SECRET="your-pipedrive-secret"
